APP_NAME=go-chat
HTTP_ADDR=:8080
STATIC_DIR=static
LOG_LEVEL=info

HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

WS_ALLOWED_ORIGINS=http://localhost:8080
WS_READ_LIMIT_BYTES=4096
WS_SEND_QUEUE_SIZE=32
WS_WRITE_WAIT=10s
WS_PONG_WAIT=60s
WS_PING_PERIOD=54s
WS_MESSAGE_LIMIT=20
WS_MESSAGE_WINDOW=10s

CHAT_HISTORY_LIMIT=100
CHAT_MAX_CLIENTS=0
CHAT_BANNED_TERMS=
